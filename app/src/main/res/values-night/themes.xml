<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MavMotors" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary Colors -->
        <item name="colorPrimary">@color/teal_dark</item>
        <item name="colorPrimaryVariant">@color/teal_blue</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary/Accent Colors -->
        <item name="colorSecondary">@color/main_orange</item>
        <item name="colorSecondaryVariant">@color/orange_dark</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Background Colors -->
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="colorSurface">@color/card_bg_dark</item>
        <item name="colorOnSurface">@color/infoTitle_dark</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/top_border_dark</item>

        <!-- Text Colors -->
        <item name="android:textColorHint">@color/hint_color_dark</item>

        <!-- Error Color -->
        <item name="colorError">@color/main_orange</item>
        <item name="colorOnError">@color/white</item>
    </style>
</resources>