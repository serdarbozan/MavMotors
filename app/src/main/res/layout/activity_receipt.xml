<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:id="@+id/receiptTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Purchase Receipt"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/receiptStatusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Purchase Completed"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp" />

    <TextView
        android:id="@+id/receiptVehicleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Vehicle: --"
        android:textSize="18sp"
        android:layout_marginBottom="10dp" />

    <TextView
        android:id="@+id/receiptPriceText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Price: --"
        android:textSize="18sp"
        android:layout_marginBottom="10dp" />

    <TextView
        android:id="@+id/receiptMethodText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Payment Method: --"
        android:textSize="18sp"
        android:layout_marginBottom="10dp" />

    <TextView
        android:id="@+id/receiptDetailsText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Details: --"
        android:textSize="18sp"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/receiptDoneButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Done" />

</LinearLayout>