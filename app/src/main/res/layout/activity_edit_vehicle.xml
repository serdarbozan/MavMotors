<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/backButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_back_arrow"
                android:padding="12dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="@string/back_button"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="?attr/colorOnSurface" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Edit Listing"
                android:textColor="?attr/colorOnSurface"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/backButton"
                app:layout_constraintTop_toTopOf="@id/backButton"
                app:layout_constraintBottom_toBottomOf="@id/backButton"
                android:layout_marginStart="8dp" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/imageLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vehicle Image"
            android:textColor="?attr/colorOnSurface"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/header" />

        <ImageView
            android:id="@+id/editVehicleImage"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="8dp"
            android:scaleType="centerCrop"
            android:src="@drawable/placeholder_car"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/vehicle_image"
            app:layout_constraintTop_toBottomOf="@id/imageLabel" />

        <TextView
            android:id="@+id/typeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Type *"
            android:textColor="?attr/colorOnSurface"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/editVehicleImage" />

        <AutoCompleteTextView
            android:id="@+id/editTypeInput"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/white_bg_round_corner"
            android:hint="Select vehicle type"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?android:attr/textColorHint"
            app:layout_constraintTop_toBottomOf="@id/typeLabel" />

        <TextView
            android:id="@+id/brandLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Brand *"
            android:textColor="?attr/colorOnSurface"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/editTypeInput" />

        <EditText
            android:id="@+id/editBrandInput"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/white_bg_round_corner"
            android:hint="e.g., Toyota, Ford, BMW"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?android:attr/textColorHint"
            app:layout_constraintTop_toBottomOf="@id/brandLabel" />

        <TextView
            android:id="@+id/modelLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Model *"
            android:textColor="?attr/colorOnSurface"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/editBrandInput" />

        <EditText
            android:id="@+id/editModelInput"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/white_bg_round_corner"
            android:hint="e.g., Camry, F-150, X5"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?android:attr/textColorHint"
            app:layout_constraintTop_toBottomOf="@id/modelLabel" />

        <TextView
            android:id="@+id/priceLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Price ($) *"
            android:textColor="?attr/colorOnSurface"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/editModelInput" />

        <EditText
            android:id="@+id/editPriceInput"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/white_bg_round_corner"
            android:hint="Enter price"
            android:inputType="number"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?android:attr/textColorHint"
            app:layout_constraintTop_toBottomOf="@id/priceLabel" />

        <TextView
            android:id="@+id/mileageLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mileage *"
            android:textColor="?attr/colorOnSurface"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/editPriceInput" />

        <EditText
            android:id="@+id/editMileageInput"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/white_bg_round_corner"
            android:hint="Enter mileage"
            android:inputType="number"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?android:attr/textColorHint"
            app:layout_constraintTop_toBottomOf="@id/mileageLabel" />

        <TextView
            android:id="@+id/yearLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Year *"
            android:textColor="?attr/colorOnSurface"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/editMileageInput" />

        <EditText
            android:id="@+id/editYearInput"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/white_bg_round_corner"
            android:hint="Enter year"
            android:inputType="number"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?android:attr/textColorHint"
            app:layout_constraintTop_toBottomOf="@id/yearLabel" />

        <TextView
            android:id="@+id/transmissionLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Transmission"
            android:textColor="?attr/colorOnSurface"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/editYearInput" />

        <AutoCompleteTextView
            android:id="@+id/editTransmissionInput"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/white_bg_round_corner"
            android:hint="Select transmission"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="Automatic"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?android:attr/textColorHint"
            app:layout_constraintTop_toBottomOf="@id/transmissionLabel" />

        <TextView
            android:id="@+id/fuelTypeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fuel Type"
            android:textColor="?attr/colorOnSurface"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/editTransmissionInput" />

        <AutoCompleteTextView
            android:id="@+id/editFuelTypeInput"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/white_bg_round_corner"
            android:hint="Select fuel type"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="Gasoline"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?android:attr/textColorHint"
            app:layout_constraintTop_toBottomOf="@id/fuelTypeLabel" />

        <TextView
            android:id="@+id/colorLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Color"
            android:textColor="?attr/colorOnSurface"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/editFuelTypeInput" />

        <EditText
            android:id="@+id/editColorInput"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/white_bg_round_corner"
            android:hint="Enter color"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="Black"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?android:attr/textColorHint"
            app:layout_constraintTop_toBottomOf="@id/colorLabel" />

        <TextView
            android:id="@+id/descriptionLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Description"
            android:textColor="?attr/colorOnSurface"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/editColorInput" />

        <EditText
            android:id="@+id/editDescriptionInput"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/white_bg_round_corner"
            android:gravity="top"
            android:hint="Enter description (optional)"
            android:inputType="textMultiLine"
            android:padding="12dp"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?android:attr/textColorHint"
            app:layout_constraintTop_toBottomOf="@id/descriptionLabel" />

        <Button
            android:id="@+id/saveChangesButton"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="?attr/colorSecondary"
            android:text="Save Changes"
            android:textColor="?attr/colorOnSecondary"
            android:textStyle="bold"
            app:cornerRadius="8dp"
            app:layout_constraintTop_toBottomOf="@id/editDescriptionInput" />

        <Button
            android:id="@+id/deleteListingButton"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="24dp"
            android:backgroundTint="#FF5252"
            android:text="Delete Listing"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:cornerRadius="8dp"
            app:layout_constraintTop_toBottomOf="@id/saveChangesButton" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>