<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="?attr/colorSurface">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Vehicle Image -->
        <ImageView
            android:id="@+id/ivAdminListingImage"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:scaleType="centerCrop"
            android:src="@drawable/placeholder_car"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Delete Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDeleteListing"
            android:layout_width="90dp"
            android:layout_height="48dp"
            android:text="Delete"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            app:backgroundTint="#FF5252"
            app:cornerRadius="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Type -->
        <TextView
            android:id="@+id/tvAdminListingType"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:text="SUV"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            app:layout_constraintTop_toTopOf="@id/ivAdminListingImage"
            app:layout_constraintStart_toEndOf="@id/ivAdminListingImage"
            app:layout_constraintEnd_toStartOf="@id/btnDeleteListing" />

        <!-- Year -->
        <TextView
            android:id="@+id/tvAdminListingYear"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:text="2023"
            android:textSize="13sp"
            android:textColor="?attr/colorOnSurface"
            android:alpha="0.7"
            android:layout_marginTop="2dp"
            app:layout_constraintTop_toBottomOf="@id/tvAdminListingType"
            app:layout_constraintStart_toEndOf="@id/ivAdminListingImage"
            app:layout_constraintEnd_toStartOf="@id/btnDeleteListing" />

        <!-- Price -->
        <TextView
            android:id="@+id/tvAdminListingPrice"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:text="$32,500"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="?attr/colorSecondary"
            android:layout_marginTop="2dp"
            app:layout_constraintTop_toBottomOf="@id/tvAdminListingYear"
            app:layout_constraintStart_toEndOf="@id/ivAdminListingImage"
            app:layout_constraintEnd_toStartOf="@id/btnDeleteListing" />

        <!-- Seller -->

        <!-- Status -->
        <TextView
            android:id="@+id/tvAdminListingSeller"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="8dp"
            android:alpha="0.6"
            android:text="Seller: username"
            android:textColor="?attr/colorOnSurface"
            android:textSize="12sp"
            app:layout_constraintEnd_toStartOf="@id/btnDeleteListing"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toEndOf="@id/ivAdminListingImage"
            app:layout_constraintTop_toBottomOf="@id/tvAdminListingPrice" />

        <TextView
            android:id="@+id/tvAdminListingStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="4dp"
            android:alpha="0.6"
            android:text="Status: Available"
            android:textColor="?attr/colorOnSurface"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@id/ivAdminListingImage"
            app:layout_constraintEnd_toStartOf="@id/btnDeleteListing"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toEndOf="@id/ivAdminListingImage"
            app:layout_constraintTop_toBottomOf="@id/tvAdminListingSeller"
            app:layout_constraintVertical_bias="0.807" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
